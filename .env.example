# Use estas variaveis quando conectar o projeto a um banco Upstash Redis pela Vercel.
# Em desenvolvimento local, se elas nao existirem, o app usa data/selections.json.

KV_REST_API_URL="https://your-upstash-instance.upstash.io"
KV_REST_API_TOKEN="your-write-token"

# Alternativamente, o app tambem aceita os nomes abaixo:
# UPSTASH_REDIS_REST_URL="https://your-upstash-instance.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-write-token"
